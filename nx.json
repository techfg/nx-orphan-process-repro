{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default"
    ],
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yaml"],
    "golang": [
      "{projectRoot}/go.mod",
      "{projectRoot}/go.sum",
      "{projectRoot}/**/*.go"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true
    }
  }  
}